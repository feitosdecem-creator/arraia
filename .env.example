# ─── Banco de dados ───────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# ─── Autenticação (NextAuth v5) ───────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET="substitua-por-string-aleatoria-de-32-bytes"

# Credenciais do painel admin (não são um usuário no banco)
ADMIN_EMAIL="admin@seu-dominio.com"
# Gere com: node -e "require('bcryptjs').hash('SUA_SENHA',12).then(console.log)"
ADMIN_PASSWORD_HASH="$2a$12$hash_gerado_pelo_bcrypt"

# ─── Mercado Pago ─────────────────────────────────────────────
# Obtenha em: https://www.mercadopago.com.br/developers/panel
MERCADOPAGO_ACCESS_TOKEN="APP_USR-..."

# Secret para validar assinatura do webhook (configure no painel do MP)
MERCADOPAGO_WEBHOOK_SECRET="seu-webhook-secret"

# ─── E-mail (Resend) ──────────────────────────────────────────
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY="re_..."

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://seu-dominio.com"

# ─── Vercel Cron ─────────────────────────────────────────────
# Gerado automaticamente pelo Vercel — NÃO definir manualmente em produção.
# Em desenvolvimento local, defina qualquer string para testar o endpoint.
CRON_SECRET="apenas-para-desenvolvimento-local"
