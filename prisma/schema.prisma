generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String               @id @default(cuid())
  name                 String
  email                String               @unique
  passwordHash         String
  phone                String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  orders               Order[]
  passwordResetTokens  PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Event {
  id          String       @id @default(cuid())
  name        String
  description String?
  date        DateTime
  location    String
  imageUrl    String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  ticketTypes TicketType[]

  @@map("events")
}

model TicketType {
  id          String      @id @default(cuid())
  eventId     String
  name        String
  description String?
  price       Int
  stock       Int
  sold        Int         @default(0)
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  event       Event       @relation(fields: [eventId], references: [id])
  orderItems  OrderItem[]
  tickets     Ticket[]

  @@map("ticket_types")
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  status        OrderStatus @default(PENDING)
  totalAmount   Int
  mercadoPagoId String?     @unique
  pixQrCode     String?
  pixQrCodeText String?
  pixExpiresAt  DateTime?
  paidAt        DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id])
  items         OrderItem[]
  tickets       Ticket[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  EXPIRED
  CANCELLED
}

model OrderItem {
  id           String     @id @default(cuid())
  orderId      String
  ticketTypeId String
  quantity     Int
  unitPrice    Int
  order        Order      @relation(fields: [orderId], references: [id])
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id])

  @@map("order_items")
}

model Ticket {
  id           String     @id @default(cuid())
  orderId      String
  ticketTypeId String
  code         String     @unique
  usedAt       DateTime?
  validatedBy  String?
  createdAt    DateTime   @default(now())
  order        Order      @relation(fields: [orderId], references: [id])
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id])

  @@map("tickets")
}

enum RaffleTransactionType {
  DELIVERY
  RETURN
  PAYMENT
  NOTE
}

model RaffleStudent {
  id           String               @id @default(cuid())
  name         String
  classroom    String
  guardian     String
  phone        String?
  code         String               @unique
  createdAt    DateTime             @default(now())
  transactions RaffleTransaction[]

  @@map("raffle_students")
}

model RaffleTransaction {
  id            String                @id @default(cuid())
  studentId     String
  type          RaffleTransactionType
  quantity      Int                   @default(0)
  amountPaid    Int?
  paymentMethod String?
  receiptNumber Int?                  @unique
  note          String?
  createdBy     String
  createdAt     DateTime              @default(now())
  student       RaffleStudent         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("raffle_transactions")
}

enum PurchaseCategory {
  ALIMENTACAO
  BEBIDAS
  DECORACAO
  BRINCADEIRAS
  ESTRUTURA
  LIMPEZA
  OUTROS
}

enum PurchaseStatus {
  PLANEJADO
  EM_COTACAO
  COMPRADO
  RECEBIDO
  CANCELADO
}

model PurchaseItem {
  id            String                 @id @default(cuid())
  name          String
  category      PurchaseCategory       @default(OUTROS)
  quantity      Float                  @default(1)
  unit          String                 @default("un")
  expectedValue Int                    @default(0)
  paidValue     Int?
  responsavel   String
  observacao    String?
  status        PurchaseStatus         @default(PLANEJADO)
  fornecedor    String?
  purchaseDate  DateTime?
  paymentMethod String?
  receiptUrl    String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  history       PurchaseHistoryEntry[]

  @@map("purchase_items")
}

model PurchaseHistoryEntry {
  id          String       @id @default(cuid())
  itemId      String
  description String
  createdBy   String
  createdAt   DateTime     @default(now())
  item        PurchaseItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("purchase_history_entries")
}
