generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String               @id @default(cuid())
  name                 String
  email                String               @unique
  passwordHash         String
  phone                String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  orders               Order[]
  passwordResetTokens  PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Event {
  id          String       @id @default(cuid())
  name        String
  description String?
  date        DateTime
  location    String
  imageUrl    String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  ticketTypes TicketType[]

  @@map("events")
}

model TicketType {
  id          String      @id @default(cuid())
  eventId     String
  name        String
  description String?
  price       Int
  stock       Int
  sold        Int         @default(0)
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  event       Event       @relation(fields: [eventId], references: [id])
  orderItems  OrderItem[]
  tickets     Ticket[]

  @@map("ticket_types")
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  status        OrderStatus @default(PENDING)
  totalAmount   Int
  mercadoPagoId String?     @unique
  pixQrCode     String?
  pixQrCodeText String?
  pixExpiresAt  DateTime?
  paidAt        DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id])
  items         OrderItem[]
  tickets       Ticket[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  EXPIRED
  CANCELLED
}

model OrderItem {
  id           String     @id @default(cuid())
  orderId      String
  ticketTypeId String
  quantity     Int
  unitPrice    Int
  order        Order      @relation(fields: [orderId], references: [id])
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id])

  @@map("order_items")
}

model Ticket {
  id           String     @id @default(cuid())
  orderId      String
  ticketTypeId String
  code         String     @unique
  usedAt       DateTime?
  validatedBy  String?
  createdAt    DateTime   @default(now())
  order        Order      @relation(fields: [orderId], references: [id])
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id])

  @@map("tickets")
}
